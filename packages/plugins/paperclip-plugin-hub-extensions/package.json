{
  "name": "@mangoclaw666/paperclip-plugin-workspace-bridge",
  "version": "0.1.0",
  "description": "Workspace Bridge — link a Paperclip company to its on-disk source and inject company-wide agent prompt defaults. Two pages: External Source + Agent Prompts. Pairs with PaperClip core changes that add the underlying DB columns and adapter fallback hook.",
  "type": "module",
  "private": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "scripts": {
    "prebuild": "pnpm --filter @paperclipai/plugin-sdk ensure-build-deps",
    "build": "tsc && node ./scripts/build-worker.mjs && node ./scripts/build-ui.mjs",
    "clean": "rm -rf dist",
    "typecheck": "pnpm --filter @paperclipai/plugin-sdk ensure-build-deps && tsc --noEmit"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
